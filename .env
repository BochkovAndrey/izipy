# Databases
POSTGRES_VERSION=18.3
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow123
POSTGRES_DB=postgres 
POSTGRES_HOST=postgres

REDIS_VERSION=8.0.3
REDIS_PASSWORD=redis123

# Airflow
AIRFLOW_VERSION=3.1.7
AIRFLOW_SECRET_KEY=supersecretkey123456789
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_WWW_USERNAME=admin
AIRFLOW_WWW_PASSWORD=admin
AIRFLOW_WWW_FIRSTNAME=Admin
AIRFLOW_WWW_LASTNAME=User
AIRFLOW_WWW_EMAIL=admin@example.com
AIRFLOW_WWW_ROLE=Admin

# Superset
SUPERSET_VERSION=6.0.0
SUPERSET_SECRET_KEY=your-superset-secret-key-change-in-production-123456
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=supersetpass
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User
SUPERSET_LOAD_EXAMPLES=false
SUPERSET_LOG_LEVEL=INFO
SUPERSET_CACHE_CONFIG={"CACHE_TYPE": "RedisCache", "CACHE_DEFAULT_TIMEOUT": 300, "CACHE_KEY_PREFIX": "superset_", "CACHE_REDIS_URL": "redis://:${REDIS_PASSWORD}@redis:6379/1"}
SUPERSET_FILTER_STATE_CACHE_CONFIG={"CACHE_TYPE": "RedisCache", "CACHE_DEFAULT_TIMEOUT": 86400, "CACHE_KEY_PREFIX": "superset_filter_", "CACHE_REDIS_URL": "redis://:${REDIS_PASSWORD}@redis:6379/1"}
SUPERSET_EXPLORE_FORM_DATA_CACHE_CONFIG={"CACHE_TYPE": "RedisCache", "CACHE_DEFAULT_TIMEOUT": 86400, "CACHE_KEY_PREFIX": "superset_explore_", "CACHE_REDIS_URL": "redis://:${REDIS_PASSWORD}@redis:6379/1"}
PYTHONPATH=/opt/airflow

# Monitoring versions
PROMETHEUS_VERSION=v3.2.0
GRAFANA_VERSION=11.5.1
NODE_EXPORTER_VERSION=v1.8.2
CADVISOR_VERSION=v0.49.2
POSTGRES_EXPORTER_VERSION=v0.17.0
REDIS_EXPORTER_VERSION=v1.66.0
BLACKBOX_EXPORTER_VERSION=v0.26.0
ALERTMANAGER_VERSION=v0.28.1
STATSD_EXPORTER_VERSION=v0.28.0

# PGAdmin
PGADMIN_VERSION=9.13
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Backup
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_HOURS=24


